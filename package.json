{
  "name": "earth-online-launcher",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "description": "Graphical RPG-style browser homepage launcher for Earth Online.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mock:github-events": "node --no-warnings scripts/generate-github-events-mock.ts",
    "sync:github-events": "node --no-warnings scripts/sync-github-events-sqlite.ts",
    "sync:github-events:watch": "node --no-warnings scripts/sync-github-events-sqlite.ts --watch"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.4.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
