{
  "name": "harness-team",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "description": "Continuous Codex CLI engineering harness.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "env -u TURBOPACK next build --webpack",
    "start": "next start",
    "vscode:build": "pnpm --dir editors/vscode build",
    "vscode:package": "pnpm --dir editors/vscode package",
    "vscode:install": "pnpm --dir editors/vscode install-local",
    "android:install-deps": "node ./projects/meow-team-apk/scripts/android-install-deps.mjs",
    "android:doctor": "node ./projects/meow-team-apk/scripts/android-doctor.mjs",
    "android:assemble": "node ./projects/meow-team-apk/scripts/android-build.mjs assembleDebug",
    "android:install": "node ./projects/meow-team-apk/scripts/android-build.mjs installDebug",
    "docs:dev": "node scripts/vitepress-runner.mjs dev",
    "docs:build": "node scripts/vitepress-runner.mjs build",
    "docs:preview": "node scripts/vitepress-runner.mjs preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "meow-prompt:sync-types": "pnpm exec vite build --configLoader runner --config packages/meow-prompt/vite-sync.config.ts",
    "typecheck": "pnpm meow-prompt:sync-types && pnpm exec next typegen && tsc -p tsconfig.typecheck.json --noEmit --incremental false",
    "fmt": "prettier --write **/*.{js,mjs,cjs,ts,mts,cts}",
    "fmt:check": "prettier --check **/*.{js,mjs,cjs,ts,mts,cts}",
    "format": "pnpm fmt",
    "format:check": "pnpm fmt:check"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "markdown-it": "14.1.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "14.1.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.8",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
