{
  "name": "harness-team",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "description": "Continuous Codex CLI engineering harness.",
  "scripts": {
    "dev": "pnpm meow-prompt:sync && env -u TURBOPACK next dev --webpack",
    "build": "pnpm meow-prompt:sync && env -u TURBOPACK next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "pnpm meow-prompt:sync && vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm meow-prompt:sync && pnpm exec next typegen && tsc -p tsconfig.typecheck.json --noEmit --incremental false",
    "meow-prompt:sync": "node packages/meow-prompt/bin/sync-template-types.cjs",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "format": "pnpm fmt",
    "format:check": "pnpm fmt:check"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
