{
  "name": "harness-team",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "description": "Continuous Codex CLI engineering harness.",
  "scripts": {
    "dev": "unset TURBOPACK; next dev --webpack",
    "build": "unset TURBOPACK; next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "meow-prompt:sync-types": "pnpm exec vite build --config packages/meow-prompt/vite-sync.config.ts",
    "typecheck": "pnpm meow-prompt:sync-types && pnpm exec next typegen && tsc -p tsconfig.typecheck.json --noEmit --incremental false",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "format": "pnpm fmt",
    "format:check": "pnpm fmt:check"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
