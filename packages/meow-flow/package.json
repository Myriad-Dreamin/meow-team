{
  "name": "meow-flow",
  "version": "0.1.61-beta.1",
  "description": "Meow Flow CLI bootstrap package",
  "type": "module",
  "files": [
    "bin",
    "dist"
  ],
  "bin": {
    "meow-flow": "bin/meow-flow"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\" && tsc -p tsconfig.json --incremental false",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@myriaddreamin/meow-flow-core": "workspace:*",
    "commander": "^12.0.0",
    "tsx": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
