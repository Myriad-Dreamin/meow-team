{
  "name": "meow-flow",
  "version": "0.1.61-beta.1",
  "description": "MeowFlow CLI bootstrap package",
  "type": "module",
  "files": [
    "bin",
    "dist"
  ],
  "bin": {
    "mfl": "bin/mfl"
  },
  "scripts": {
    "build": "node scripts/embed-skills.mjs && node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\" && tsc -p tsconfig.json --incremental false",
    "embed-skills": "node scripts/embed-skills.mjs",
    "prepack": "pnpm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^12.0.0",
    "tsx": "^4.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.9.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
